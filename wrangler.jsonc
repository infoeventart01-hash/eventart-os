{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "eventart",
  "compatibility_date": "2026-05-22",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "main": "./worker/index.ts",
  "secrets": {
    "required": [
      "AIRTABLE_BASE_ID",
      "AIRTABLE_TOKEN"
    ]
  },
  "assets": {
    "directory": "dist/client",
    "not_found_handling": "none",
    "binding": "ASSETS"
  },
  "images": {
    "binding": "IMAGES"
  }
}
